{
  "name": "@jimjammcjames/ai-changelog-action",
  "version": "1.1.0",
  "description": "AI-powered changelog generator from git commits and PRs \u2014 GitHub Action + CLI",
  "main": "dist/index.js",
  "bin": {
    "ai-changelog": "dist/cli.js"
  },
  "files": [
    "dist/",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./core": "./dist/core.js",
    "./cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "build:cli": "ncc build src/cli.ts -o dist-cli --source-map --license licenses.txt && cp dist-cli/index.js dist/cli.js && cp dist-cli/index.js.map dist/cli.js.map && rm -rf dist-cli",
    "build:all": "npm run build && npm run build:cli",
    "test": "jest --coverage",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "github-action",
    "changelog",
    "ai",
    "release-notes",
    "conventional-commits",
    "cli",
    "semver"
  ],
  "author": "DuglePlex",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jimjammcjames/ai-changelog-action.git"
  }
}
